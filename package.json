{
  "name": "groq-coder",
  "displayName": "Groq Coder",
  "description": "AI coding assistant using Groq — fast models, plan mode, file creation",
  "version": "0.1.3",
  "license": "MIT",
  "icon": "media/icon128.png",
  "publisher": "innocentmanda",
  "repository": {
    "type": "git",
    "url": "https://github.com/Innosgram/groq-coder"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "groq-coder",
          "title": "Groq Coder",
          "icon": "media/groq-icon.svg"
        }
      ]
    },
    "views": {
      "groq-coder": [
        {
          "type": "webview",
          "id": "groqCoder.chatView",
          "name": "Groq Coder",
          "icon": "media/groq-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "groqCoder.startChat",
        "title": "Start Groq Chat",
        "category": "Groq Coder"
      }
    ],
    "configuration": {
      "title": "Groq Coder",
      "properties": {
        "groqCoder.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Groq API Key (you can also set this directly in the chat panel)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./"
  },
  "dependencies": {
    "groq-sdk": "^0.3.3"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  }
}
